# ChargeWise configuration — copy to .env and fill in. NEVER commit your real .env.
# Read by backend/chargewise/config.py (pydantic-settings; unknown keys ignored).
# In the NAS deployment, docker-compose.nas.yml loads this via `env_file: .env`.

# Auth toggle: true for local dev / LAN-only deployments (no login required).
AUTH_DISABLED=true

# --- TeslaFi (history API) --- REQUIRED for TeslaFi ingestion
TESLAFI_TOKEN=your-teslafi-api-token

# --- Octopus Energy --- REQUIRED for Octopus ingestion
OCTOPUS_API_KEY=sk_live_xxx
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# --- Cost settings ---
AWAY_RATE_GBP_PER_KWH=0.50      # fallback when a public charge has no recorded cost
PETROL_MPG=30                   # petrol comparator (Alistair's prior car ~29-32 mpg)
FUEL_TYPE=petrol                # petrol | diesel
EXCLUDE_STANDING_CHARGE=true    # standing charge is a fixed home cost, not a charging cost

# --- Storage ---
DATABASE_URL=sqlite:///./data/chargewise.sqlite

# --- Future (parked): OAuth login + Azure deployment ---
# The internet-facing dashboard (OAuth via Microsoft/Google) and the Azure/Key
# Vault deployment are deliberately parked — the LAN-first v1 shipped instead.
# These keys are read by config.py but unused while AUTH_DISABLED=true.
OAUTH_PROVIDER=microsoft        # microsoft | google
OAUTH_CLIENT_ID=
SESSION_SECRET=change-me
KEY_VAULT_NAME=                 # Azure Key Vault name; leave blank
