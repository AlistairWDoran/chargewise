# ChargeWise configuration — copy to .env and fill in. NEVER commit your real .env.
# In Azure, the secret values below are stored in Azure Key Vault and injected
# as environment variables (Container Apps secrets / Key Vault references) — so
# secrets live only in Key Vault and in your local .env, never in git.

# Auth toggle: true for local dev (no login required); false in production.
AUTH_DISABLED=true
# Azure Key Vault name (production); leave blank for local dev.
KEY_VAULT_NAME=

# --- TeslaFi (history API, beta) ---
TESLAFI_TOKEN=your-teslafi-api-token

# --- Octopus Energy ---
OCTOPUS_API_KEY=sk_live_xxx
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# --- Cost settings ---
AWAY_RATE_GBP_PER_KWH=0.50      # fallback when a public charge has no recorded cost
PETROL_MPG=30                   # petrol comparator (Alistair's prior car ~29-32 mpg)
FUEL_TYPE=petrol                # petrol | diesel
EXCLUDE_STANDING_CHARGE=true    # standing charge is a fixed home cost, not a charging cost

# --- App / auth (internet-facing dashboard uses OAuth) ---
APP_BASE_URL=http://localhost:8000
OAUTH_PROVIDER=microsoft        # microsoft | google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
SESSION_SECRET=change-me

# --- Storage ---
DATABASE_URL=sqlite:///./data/chargewise.sqlite
